<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="boundary.ReportPanel">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="4b2e9" binding="headerPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="b5aa" class="javax.swing.JLabel" binding="labelTitolo">
            <constraints border-constraint="West"/>
            <properties>
              <text value="Label"/>
            </properties>
          </component>
          <component id="eae11" class="javax.swing.JButton" binding="bottoneIndietro">
            <constraints border-constraint="East"/>
            <properties>
              <text value="Indietro"/>
            </properties>
          </component>
        </children>
      </grid>
      <grid id="76d45" binding="contenutoPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="a465d" binding="panelStatistiche" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="North"/>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="30cbc" binding="panelGrafico" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children/>
          </grid>
        </children>
      </grid>
      <grid id="c1049" binding="panelSaldi" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="South"/>
        <properties/>
        <border type="none"/>
        <children/>
      </grid>
    </children>
  </grid>
</form>
