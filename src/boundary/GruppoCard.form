<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="boundary.GruppoCard">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="empty">
      <size top="12" left="16" bottom="12" right="16"/>
    </border>
    <children>
      <grid id="69f31" binding="infoPanel" layout-manager="GridLayoutManager" row-count="2" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
        <margin top="0" left="0" bottom="0" right="0"/>
        <constraints border-constraint="West"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="9e151" class="javax.swing.JLabel" binding="labelNome">
            <constraints>
              <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="14" style="1"/>
              <text value="Nome Gruppo"/>
            </properties>
          </component>
          <component id="e2a1e" class="javax.swing.JLabel" binding="labelRuolo">
            <constraints>
              <grid row="1" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="0" anchor="8" fill="0" indent="0" use-parent-layout="false"/>
            </constraints>
            <properties>
              <font size="11"/>
              <foreground color="-8224126"/>
              <text value="Proprietario"/>
            </properties>
          </component>
        </children>
      </grid>
      <component id="9003b" class="javax.swing.JLabel" binding="labelStats">
        <constraints border-constraint="Center"/>
        <properties>
          <horizontalAlignment value="0"/>
          <text value="3 partecipanti · 12 spese"/>
        </properties>
      </component>
      <component id="e2a0" class="javax.swing.JLabel" binding="labelSaldo">
        <constraints border-constraint="East"/>
        <properties>
          <font size="14" style="1"/>
          <text value="+45,00 €"/>
        </properties>
      </component>
    </children>
  </grid>
</form>
