<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="boundary.DettaglioGruppoPanel">
  <grid id="27dc6" binding="panel1" default-binding="true" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="12f24" binding="headerPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="North"/>
        <properties/>
        <border type="none"/>
        <children>
          <component id="28fa7" class="javax.swing.JLabel" binding="labelNomeGruppo">
            <constraints border-constraint="West"/>
            <properties>
              <text value="Nome gruppo"/>
            </properties>
          </component>
          <grid id="da681" binding="pannelloBottoni" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
            <constraints border-constraint="East"/>
            <properties/>
            <border type="none"/>
            <children>
              <component id="f41ee" class="javax.swing.JButton" binding="bottoneNuovaSpesa">
                <constraints/>
                <properties>
                  <text value="Nuova spesa"/>
                </properties>
              </component>
              <component id="d44bd" class="javax.swing.JButton" binding="bottoneAzzeraSaldo">
                <constraints/>
                <properties>
                  <text value="Azzera saldo"/>
                </properties>
              </component>
              <component id="d63b2" class="javax.swing.JButton" binding="bottoneReport">
                <constraints/>
                <properties>
                  <text value="Vedi report"/>
                </properties>
              </component>
            </children>
          </grid>
        </children>
      </grid>
      <grid id="5f681" binding="contenutoPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties/>
        <border type="none"/>
        <children>
          <grid id="28413" binding="pannelloSaldi" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="Center"/>
            <properties/>
            <border type="none"/>
            <children>
              <scrollpane id="8186f" binding="TabellaSpese">
                <constraints border-constraint="Center"/>
                <properties/>
                <border type="none"/>
                <children>
                  <component id="d70b9" class="javax.swing.JTable" binding="tabellaSpese">
                    <constraints/>
                    <properties/>
                  </component>
                </children>
              </scrollpane>
            </children>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>
